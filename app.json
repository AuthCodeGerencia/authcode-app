{
  "expo": {
    "name": "Authcode",
    "slug": "authcode-app",
    "version": "1.0.1",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0f0f0f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "appleTeamId": "87DK3Z664S",
      "bundleIdentifier": "com.authcodetechnologies.authcodeapp",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F0F",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.authcodetechnologies.authcodeapp"
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "313a7137-7dd3-4888-bef5-2805d7f5fac2"
      }
    },
    "owner": "authcode",
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#111111",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.authcodetechnologies.authcodeapp.widgets",
          "groupIdentifier": "group.com.authcodetechnologies.authcodeapp",
          "frequentUpdates": true,
          "widgets": [
            {
              "name": "AuthcodeTimer",
              "displayName": "Authcode Timer",
              "description": "Timer activo de Authcode",
              "supportedFamilies": ["systemSmall"]
            }
          ]
        }
      ]
    ]
  }
}
